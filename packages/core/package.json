{
  "name": "@fabrknt/complr-core",
  "version": "1.0.3",
  "description": "AI-powered compliance engine for digital assets — regulatory intelligence, screening, and reporting",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "complr": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "start:server": "node dist/api/server.js",
    "typecheck": "tsc --noEmit",
    "demo": "tsx src/demo.ts",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "cheerio": "^1.0.0",
    "express": "^4.18.2",
    "puppeteer": "^19.0.0",
    "puppeteer-screen-recorder": "^3.0.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "license": "MIT"
}
