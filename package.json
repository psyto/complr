{
  "name": "complr",
  "version": "0.1.0",
  "description": "AI-powered compliance infrastructure for the digital asset industry",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "complr": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "start:server": "node dist/api/server.js",
    "typecheck": "tsc --noEmit",
    "demo": "tsx src/demo.ts",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "cheerio": "^1.0.0",
    "express": "^4.18.2",
    "puppeteer": "^19.0.0",
    "puppeteer-screen-recorder": "^3.0.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
