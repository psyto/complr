{
  "name": "Fabrknt Off-Chain Compliance",
  "slug": "fabrknt-offchain-compliance",
  "version": "1.0.0",
  "description": "AI-powered cryptocurrency compliance, regulatory screening, and SAR/STR reporting for multi-chain dApps.",
  "author": "Fabrknt",
  "chains": [
    {
      "id": "solana",
      "name": "Solana"
    },
    {
      "id": "ethereum",
      "name": "Ethereum"
    }
  ],
  "healthcheck": "/healthcheck",
  "provision": {
    "url": "/provision",
    "method": "POST",
    "deactivate_url": "/provision/deactivate",
    "deprovision_url": "/provision"
  },
  "plans": [
    {
      "id": "starter",
      "name": "Starter",
      "price": 0,
      "description": "Free tier with essential compliance tools.",
      "features": [
        "Regulatory queries",
        "Single transaction compliance check",
        "Address screening (OFAC/sanctions)",
        "3 jurisdictions (MAS, SFC, FSA)"
      ],
      "rate_limit": {
        "requests_per_minute": 50
      }
    },
    {
      "id": "pro",
      "name": "Pro",
      "price": 99,
      "description": "Full compliance suite for production use.",
      "features": [
        "Everything in Starter",
        "Batch transaction compliance checks (up to 50)",
        "SAR/STR report generation",
        "Wallet risk screening",
        "Batch address screening (up to 100)",
        "Webhook notifications",
        "Priority support"
      ],
      "rate_limit": {
        "requests_per_minute": 200
      }
    }
  ],
  "api": {
    "endpoints": [
      {
        "method": "POST",
        "path": "/v1/check",
        "description": "Single transaction compliance check",
        "plans": ["starter", "pro"]
      },
      {
        "method": "POST",
        "path": "/v1/check/batch",
        "description": "Batch transaction compliance check (max 50)",
        "plans": ["pro"]
      },
      {
        "method": "POST",
        "path": "/v1/query",
        "description": "Regulatory query",
        "plans": ["starter", "pro"]
      },
      {
        "method": "POST",
        "path": "/v1/report",
        "description": "SAR/STR report generation",
        "plans": ["pro"]
      },
      {
        "method": "POST",
        "path": "/v1/screen/wallet",
        "description": "Wallet risk screening",
        "plans": ["pro"]
      },
      {
        "method": "POST",
        "path": "/v1/screen/address",
        "description": "Address sanctions screening",
        "plans": ["starter", "pro"]
      },
      {
        "method": "POST",
        "path": "/v1/screen/batch",
        "description": "Batch address screening (max 100)",
        "plans": ["pro"]
      }
    ]
  }
}
